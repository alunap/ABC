# Function to convert 4-figure OS grid ref (e.g., "NR7419") to easting/northing (centre of 1km square)
os_to_coords <- function(gridref) {
# Extract letters and numbers
letters <- str_sub(gridref, 1, 2)
nums <- str_sub(gridref, 3, 6)
east_100km <- as.integer(substr(letters, 1, 1)) # better: use proper lookup for 100km square
# Full robust conversion needs a lookup for the 100km square letters
# Simpler: use the 'rgdal' / 'sp' legacy or a dedicated package
# Install if needed: install.packages("osgrid")
}
# Better: use the 'osgrid' or 'sf' + manual calculation (most reliable for 4-figure)
# Here's a clean function using known OS rules:
grid_to_sf <- function(gridref) {
# 4-figure: letters (2) + 2 digits east + 2 digits north → 1km resolution
sq <- str_sub(gridref, 1, 2)
e <- as.numeric(str_sub(gridref, 3, 4)) * 1000 # km to m, lower left
n <- as.numeric(str_sub(gridref, 5, 6)) * 1000
# Add the 100km square offset (lookup table needed for full accuracy)
# For Argyll/Inner Hebrides area (NR, NM, NL, NS, NN etc.), here's a quick map:
# Common in your data: NR → easting base ~170000, northing ~640000 (approx)
# Better to use a proper converter.
# Recommended package: install.packages("rnrfa") or use this manual for your region
}
