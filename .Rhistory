}
jags_model <- "
model {
# --- Priors ---
psi   ~ dbeta(1, 1)        # occupancy probability
p     ~ dbeta(1, 1)        # detection probability
lambda ~ dgamma(1, 0.01)   # expected count given presence
# --- Ecological process ---
for (i in 1:nSites) {
z[i] ~ dbern(psi)        # true occupancy state
# --- Observation process ---
for (v in 1:nVisits) {
# Only model surveyed site-visits
y[i,v] ~ dbern(p.eff[i,v])
p.eff[i,v] <- z[i] * p * is_obs[i,v]
# Censored count sub-model:
# N[i,v] is the true (latent) count
# dinterval gives the censoring constraint:
#   C[i,v] = 0 means c_lo <= N < c_hi  (interval or exact)
#   C[i,v] = 1 means N >= c_hi          (right-censored '+')
#
# For unvisited cells is_obs=0, fix N to 0 to avoid sampling
lam.eff[i,v] <- lambda * z[i] * is_obs[i,v] + 0.001
N[i,v]    ~ dpois(lam.eff[i,v])
C[i,v]    ~ dinterval(N[i,v], c_bounds[i,v,])
}
}
# --- Derived quantities ---
Nocc <- sum(z[])           # number of occupied sites
psi.hat <- Nocc / nSites   # realised occupancy
}
"
# Build 3D bounds array [nSites, nVisits, 2]
c_bounds <- array(0, dim = c(nSites, nVisits, 2))
C_obs <- matrix(0, nrow = nSites, ncol = nVisits)
for (i in 1:nSites) {
for (v in 1:nVisits) {
lo <- c_lo[i, v]
hi <- c_hi[i, v]
if (is_obs[i, v] == 1) {
c_bounds[i, v, 1] <- max(lo - 1, 0) # lower cut
c_bounds[i, v, 2] <- ifelse(hi >= M_censor, 1e6, hi) # upper cut
C_obs[i, v] <- 1 # N falls above lower cut
}
}
}
# Initial values for latent N (must satisfy censoring at init)
N_init <- matrix(NA, nrow = nSites, ncol = nVisits)
for (i in 1:nSites) {
for (v in 1:nVisits) {
if (is_obs[i, v] == 1) {
N_init[i, v] <- max(round((c_lo[i, v] + min(c_hi[i, v], c_lo[i, v] + 10)) / 2), 1)
} else {
N_init[i, v] <- 0
}
}
}
jags_data <- list(
nSites   = nSites,
nVisits  = nVisits,
y        = y,
is_obs   = is_obs,
N        = N_init, # latent counts (partially observed)
C        = C_obs, # censoring indicator
c_bounds = c_bounds
)
inits <- function() {
list(
z      = rep(1, nSites),
psi    = runif(1, 0.3, 0.7),
p      = runif(1, 0.3, 0.7),
lambda = runif(1, 5, 20)
)
}
params <- c("psi", "p", "lambda", "Nocc", "psi.hat", "z")
cat("Compiling JAGS model...\n")
jm <- jags.model(
textConnection(jags_model),
data = jags_data,
inits = inits,
n.chains = 3,
n.adapt = 1000
)
library(rjags)
library(dplyr)
library(lubridate)
library(tidyr)
# ------------------------------------------------------------
# 1. DATA PREPARATION
# ------------------------------------------------------------
bird_data <- read.csv("data/exp_pro/ABC_2000_2022.csv")
parse_count <- function(x) {
x <- trimws(as.character(x))
# Returns a two-column matrix: [lower, upper]
# Exact integer
if (grepl("^\\d+$", x)) {
val <- as.numeric(x)
return(c(lower = val, upper = val))
}
# "Present" -> at least 1, upper unknown -> use large sentinel
if (tolower(x) == "present") {
return(c(lower = 1, upper = NA))
}
# "25+" -> at least 25
if (grepl("^\\d+\\+$", x)) {
val <- as.numeric(sub("\\+", "", x))
return(c(lower = val, upper = NA))
}
# "200-500" -> interval
if (grepl("^\\d+-\\d+$", x)) {
parts <- as.numeric(strsplit(x, "-")[[1]])
return(c(lower = parts[1], upper = parts[2]))
}
# NA / zero / unknown
return(c(lower = 0, upper = 0))
}
# Filter to one species
focal_species <- "Yellowhammer"
df <- bird_data %>%
filter(Species == focal_species) %>%
mutate(
Year    = year(as.Date(Date)),
parsed  = lapply(Count, parse_count),
lower   = sapply(parsed, `[`, "lower"),
upper   = sapply(parsed, `[`, "upper")
)
# Sentinel: use Inf directly for right-censored upper bounds
M_CENSOR <- Inf
# Re-parse your data with Inf for right-censored
df <- df %>%
mutate(
c_hi_jags = ifelse(is.na(c_hi) & !is.na(c_lo), Inf, c_hi)
)
View(df)
# Re-parse your data with Inf for right-censored
df <- df %>%
mutate(
c_hi_jags = ifelse(is.na(upper) & !is.na(lower), Inf, upper)
)
View(df)
# Rebuild site x visit arrays with corrected bounds
y_lo <- matrix(NA_real_, nSites, nVisits)
sites  <- sort(unique(df$Gridref))
nSites <- length(sites)
# Maximum number of repeat visits across all sites
visits_per_site <- df %>% count(Gridref)
nVisits <- max(visits_per_site$n)
# Rebuild site x visit arrays with corrected bounds
y_lo <- matrix(NA_real_, nSites, nVisits)
y_hi <- matrix(NA_real_, nSites, nVisits)
is_obs <- matrix(0L, nSites, nVisits)
for (i in seq_along(sites)) {
sv <- df %>%
filter(GridRef == sites[i]) %>%
arrange(Date) %>%
mutate(v = row_number())
for (r in 1:nrow(sv)) {
v <- sv$v[r]
is_obs[i, v] <- 1L
y_lo[i, v] <- sv$c_lo[r]
y_hi[i, v] <- sv$c_hi_jags[r]
}
}
for (i in seq_along(sites)) {
sv <- df %>%
filter(Gridref == sites[i]) %>%
arrange(Date) %>%
mutate(v = row_number())
for (r in 1:nrow(sv)) {
v <- sv$v[r]
is_obs[i, v] <- 1L
y_lo[i, v] <- sv$c_lo[r]
y_hi[i, v] <- sv$c_hi_jags[r]
}
}
library(dplyr)
library(tidyr)
library(here)
birds <- read.csv("data/exp_pro/ABC_2000_2022.csv")
df <- birds %>%
# Filter to one focal species first (repeat for each species or do community later)
filter(Species == "Dipper") %>% # e.g. "Barnacle Goose"
mutate(
Gridref = as.character(Gridref),
Date = as.character(Date),
# Parse Count column – works whether it is numeric or string
Count_str = as.character(Count),
# Extract lower and upper bounds
lower = case_when(
grepl("\\+", Count_str) ~ as.numeric(gsub("\\+", "", Count_str)), # "10+" → 10
grepl("-", Count_str) ~ as.numeric(gsub("-.*", "", Count_str)), # "200-500" → 200
TRUE ~ as.numeric(Count_str) # exact number
),
upper = case_when(
grepl("\\+", Count_str) ~ Inf, # right-censored
grepl("-", Count_str) ~ as.numeric(gsub(".*-", "", Count_str)), # "200-500" → 500
TRUE ~ as.numeric(Count_str) # exact
)
) %>%
# Each (Gridref, Date) is one survey
group_by(Gridref, Date) %>%
summarise(
lower = max(lower, na.rm = TRUE), # in case of multiple entries (rare)
upper = max(upper, na.rm = TRUE),
.groups = "drop"
) %>%
ungroup()
# Create site index
df <- df %>%
mutate(siteID = as.integer(factor(Gridref)))
# Nimble data objects
nimble_data <- list(
lower   = df$lower,
upper   = df$upper
)
nimble_constants <- list(
K       = nrow(df), # total number of surveys (site-date combinations)
n_site  = length(unique(df$siteID)),
siteID  = df$siteID
)
#####################################################
#               NIMBLE Mode Code                    #
#####################################################
library(nimble)
n_mixture_censored <- nimbleCode({
# Priors
beta0 ~ dnorm(0, sd = 10) # intercept for log(lambda)
# beta1 ~ dnorm(0, sd = 2)     # slope for a site covariate (uncomment if you add one)
sigma_site ~ dunif(0, 5) # optional site random effect
tau_site <- 1 / (sigma_site * sigma_site)
# Site-level abundance
for (s in 1:n_site) {
site_effect[s] ~ dnorm(0, tau_site)
log(lambda[s]) <- beta0 + site_effect[s] # + beta1 * elev[s] if you have a covariate
N[s] ~ dpois(lambda[s]) # latent abundance at site s
}
# Detection probability (constant across surveys for simplicity)
p ~ dunif(0, 1)
# Likelihood – each survey (site-date) has a censored observation
for (k in 1:K) {
true_count[k] ~ T(dbin(p, N[siteID[k]]), lower[k], upper[k])
# true_count is the latent number of birds actually present and detected
# The T() truncation enforces the censoring information you observed
}
# Derived quantities
mean_lambda <- mean(lambda[1:n_site])
total_abundance <- sum(N[1:n_site])
})
# Initial values – very important for censored models
inits <- function() {
list(
beta0       = 0,
sigma_site  = 0.5,
site_effect = rnorm(nimble_constants$n_site, 0, 0.5),
N           = pmax(ceiling(nimble_data$lower / 0.3), 5), # start above lower bound
true_count  = pmax(nimble_data$lower, 1),
p           = 0.5
)
}
# Build the model
model <- nimbleModel(n_mixture_censored,
constants = nimble_constants,
data      = nimble_data,
inits     = inits()
)
cModel <- compileNimble(model)
# Configure MCMC
conf <- configureMCMC(cModel,
monitors = c(
"beta0", "p", "sigma_site",
"mean_lambda", "total_abundance",
"N[1:10]"
)
) # monitor a few N for checking
mcmc <- buildMCMC(conf)
cMCMC <- compileNimble(mcmc, project = cModel)
# Run (start conservative, then increase)
cMCMC$run(niter = 15000, nburnin = 5000, thin = 5) # nchains = 3,
